---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import ComingNext from '../components/ComingNext.astro';
import EmailSignup from '../components/EmailSignup.astro';
---

<BaseLayout
  title="Caleb Arlow · The Pairing"
  description="The Pairing series by Caleb Arlow. A 12-book YA fantasy romance where bonds appear as colored threads, the system maps them, and a girl with a white thread is the variable nobody coded for. Free with Kindle Unlimited."
>
  <!-- Hero -->
  <section class="page-hero" style="padding-top: var(--s-10); padding-bottom: var(--s-9);">
    <div class="wrap-text" style="text-align: center;">
      <p class="t-eyebrow reveal" style="justify-content: center;">12-book YA fantasy romance &middot; The Pairing</p>
      <h1 class="reveal d1" style="margin-left: auto; margin-right: auto;">
        Every bond is a thread.
        <span class="em-italic" style="display: block; font-size: 0.78em; margin-top: var(--s-3);">Hers shouldn't exist.</span>
      </h1>
      <p class="lead reveal d2" style="margin-left: auto; margin-right: auto;">
        Lira sees a color the system says is impossible. The boy on the other end of her thread is the one person who's not supposed to know. Fated bond. Slow burn. A regime that wants them dissolved.
      </p>
      <div class="page-hero-actions reveal d3" style="justify-content: center;">
        <a class="btn btn-primary" href="/books/thread-of-gold">Start with Thread of Gold</a>
        <a class="btn btn-ghost" href="/the-pairing">Inside the world</a>
      </div>
      <p class="reveal d3" style="margin-top: var(--s-5); font-size: 0.8rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--paper-300);">
        &#9733; All three books free in Kindle Unlimited
      </p>
    </div>
  </section>

  <!-- Books grid -->
  <section class="section">
    <div class="wrap">
      <div class="section-head" style="display: flex; justify-content: space-between; align-items: end; gap: var(--s-5); flex-wrap: wrap;">
        <div>
          <p class="t-eyebrow">The first three books</p>
          <h2 class="t-h2" style="margin-top: var(--s-3);">Available now.</h2>
        </div>
        <a class="btn-text" href="/books">See all books</a>
      </div>

      <div class="book-grid-three">
        <BookCard
          cover="/covers/thread-of-gold.png"
          coverAlt="Thread of Gold cover"
          meta="Book One &middot; Free in KU"
          title="Thread of Gold"
          blurb="Lira's thread is gold. Gold isn't supposed to exist. Tieran is on the other end of it, and the system that paired them has never seen a bond like this. Fated. Watched. Already dangerous."
          amazonUrl="https://www.amazon.com/Thread-Gold-Pairing-Caleb-Arlow/dp/B0GNKB2N8Q/"
          detailUrl="/books/thread-of-gold"
        />
        <BookCard
          cover="/covers/thread-of-silver.png"
          coverAlt="Thread of Silver cover"
          meta="Book Two &middot; Free in KU"
          title="Thread of Silver"
          blurb="They came for Lira at the library. They came for Tieran an hour later. Now she's in a cell and he's being made to listen. Her thread is the only way to reach him, and using it might be the thing that snaps it."
          amazonUrl="https://www.amazon.com/Thread-Silver-Pairing-Book-ebook/dp/B0GSJ97FQX/"
          detailUrl="/books/thread-of-silver"
        />
        <BookCard
          cover="/covers/thread-of-white.png"
          coverAlt="Thread of White cover"
          meta="Book Three &middot; Free in KU"
          title="Thread of White"
          blurb="Lira is a prisoner. Her thread is older than the system that built her cell. Tieran is leading the rescue. The choice at the end of this book breaks the Discovery arc wide open."
          amazonUrl="https://www.amazon.com/dp/B0GZ93ZSM4"
          detailUrl="/books/thread-of-white"
        />
      </div>
    </div>
  </section>

  <!-- Coming next -->
  <ComingNext
    bookNumber={4}
    arc="Rebellion arc"
    teaser="Two years after Thread of White. The resistance has a name. Lira and Tieran are no longer hiding, and their bond is a target. Trust is the most dangerous thing in the world."
  />

  <!-- World snippet -->
  <section class="section section-tinted">
    <div class="wrap-text" style="text-align: center;">
      <p class="t-eyebrow silver" style="justify-content: center;">The world</p>
      <h2 class="t-h2" style="margin: var(--s-3) 0 var(--s-5);">
        Every citizen gets a thread at thirteen.
      </h2>
      <p class="body-text" style="max-width: 56ch; margin: 0 auto;">
        The color tells the system what to do with you. Gold is rare. Red gets watched. Gray means the system has interfered. White is not supposed to exist. Lira is the variable nobody coded for.
      </p>
      <a class="btn btn-ghost" href="/the-pairing" style="margin-top: var(--s-6);">Inside the world</a>
    </div>
  </section>

  <!-- For fans of -->
  <section class="section">
    <div class="wrap-text" style="text-align: center;">
      <p class="t-eyebrow" style="justify-content: center;">For readers of</p>
      <h2 class="t-h3" style="margin: var(--s-3) 0 var(--s-5);">
        <span class="em-italic">Matched</span> &middot; <span class="em-italic">Delirium</span> &middot; <span class="em-italic">Red Queen</span> &middot; <span class="em-italic">Powerless</span>
      </h2>
      <p class="body-text" style="max-width: 56ch; margin: 0 auto;">
        Forbidden romance. Color-coded magic. A government that decides who gets to love who. A bond that refuses to be the thing the system wants it to be.
      </p>
    </div>
  </section>

  <!-- Email signup -->
  <section class="section section-tinted">
    <div class="wrap">
      <EmailSignup
        headline="Get Book Four before anyone else."
        sub="New release alerts, cover reveals, and early chapters drop in the newsletter first. No spam, no filler."
      />
    </div>
  </section>
</BaseLayout>
