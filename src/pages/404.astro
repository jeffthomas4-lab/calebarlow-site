---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · Caleb Arlow">
  <section class="page-hero" style="text-align: center; padding: var(--s-10) 0;">
    <div class="wrap-text">
      <p class="t-eyebrow" style="justify-content: center;">404</p>
      <h1 style="margin-left: auto; margin-right: auto;">
        That thread <span class="em-italic">snapped.</span>
      </h1>
      <p class="lead" style="margin-left: auto; margin-right: auto;">
        The page you were looking for is gone, was renamed, or never existed. Both of us can pretend it was the last one.
      </p>
      <div class="page-hero-actions" style="justify-content: center;">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/books">See the books</a>
      </div>
    </div>
  </section>
</BaseLayout>
